# Moonshot / Kimi K2
MOONSHOT_API_KEY=your_moonshot_api_key_here

# Supabase — server side (service role, never expose to frontend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Supabase — frontend (anon key, safe to expose)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# API URL (empty = Vite proxy in dev; set to backend URL in prod)
VITE_API_URL=

# Tavily — web search for AI Agent
TAVILY_API_KEY=your_tavily_api_key_here

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=https://www.gsyen.com,https://gsyen.com
