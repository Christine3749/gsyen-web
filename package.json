{
  "name": "gsyen",
  "private": true,
  "version": "2.80.156",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "electron:dev": "concurrently \"vite\" \"wait-on http://127.0.0.1:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "vite build && electron-builder",
    "electron:preview": "cross-env NODE_ENV=production electron .",
    "version:help": "node -e \"console.log('\\n发布流程\\n──────────────────────────────────────\\n1. 改完代码\\n2. npm run version:fix    (小修 patch++)\\n   npm run version:feat   (新功能 功能点++)\\n   npm run version:era    (里程碑 大版本++)\\n3. npm run version:release  ← 一键：stage all + commit + tag + push\\n   → GitHub Actions 自动打 Windows .exe + Mac .dmg\\n   → Vercel 同步更新 Web\\n\\n版本规则  v{大版本}.{功能点}.{patch}\\n')\"",
    "version:fix": "npm version patch --no-git-tag-version",
    "version:feat": "node -e \"const v=require('./package.json').version.split('.');v[1]=String(Number(v[1])+1);const nv=v.join('.');require('child_process').execSync('npm version '+nv+' --no-git-tag-version',{stdio:'inherit'});\"",
    "version:era": "node -e \"const v=require('./package.json').version.split('.');v[0]=String(Number(v[0])+1);v[2]='0';const nv=v.join('.');require('child_process').execSync('npm version '+nv+' --no-git-tag-version',{stdio:'inherit'});\"",
    "version:release": "node -e \"const v=require('./package.json').version;require('child_process').execSync('git add -A && git commit -m \\\"release: v'+v+'\\\" && git tag v'+v+' && git push && git push --tags',{stdio:'inherit'});\""
  },
  "build": {
    "appId": "com.gsyen.app",
    "productName": "GSYEN",
    "copyright": "Copyright © 2026 GSYEN",
    "directories": {
      "output": "../gsyen-dist"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico",
      "artifactName": "GSYEN-Setup-Windows.exe",
      "extraResources": [
        {
          "from": "public/icon.ico",
          "to": "icon.ico"
        },
        {
          "from": "electron/v2ray-core",
          "to": "v2ray-core",
          "filter": [
            "**/*"
          ]
        },
        {
          "from": "electron/v2ray-nodes.json",
          "to": "v2ray-nodes.json"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "GSYEN",
      "menuCategory": "GSYEN",
      "deleteAppDataOnUninstall": true,
      "installerLanguages": [
        "zh_CN",
        "en_US"
      ],
      "language": "2052"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "public/icon-512.png",
      "artifactName": "GSYEN-Setup-Mac-${arch}.dmg",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": "AppImage"
    },
    "publish": {
      "provider": "generic",
      "url": "https://pub-e31e040936184655b82ef435a00e4676.r2.dev"
    }
  },
  "dependencies": {
    "@sentry/electron": "^7.13.0",
    "@sentry/react": "^10.57.0",
    "@supabase/ssr": "^0.12.0",
    "@xyflow/react": "^12.11.0",
    "electron-updater": "^6.8.9",
    "mermaid": "^11.15.0"
  },
  "devDependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.1",
    "@excalidraw/excalidraw": "^0.18.1",
    "@supabase/supabase-js": "^2.106.2",
    "@tailwindcss/vite": "^4.1.14",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@uiw/react-codemirror": "^4.25.10",
    "@vercel/node": "^5.8.4",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "esbuild": "^0.25.0",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "png-to-ico": "^3.0.1",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "wait-on": "^9.0.10"
  }
}
